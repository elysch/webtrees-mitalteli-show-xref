                        <button class="btn btn-outline-secondary" type="button" onclick="addCustomSymbol(); return false;"><?= I18N::translate('Add') ?></button>
                    </div>
                </div>
            </div>
            <script>
            function addCustomSymbol() {
                const input = document.getElementById('new-custom-symbol');
                const symbol = input.value.trim();
                if (symbol.length > 0 && symbol.length <= 2) {
                    const group = document.getElementById('symbol-buttons-group');
                    const button = document.createElement('button');
                    button.type = 'button';
                    button.className = 'btn btn-outline-secondary btn-sm';
                    button.textContent = symbol;
                    button.onclick = function() {
                        document.getElementById('link-symbol').value = symbol;
                        return false;
                    };
                    group.appendChild(button);
                    input.value = '';
                }
            }
            document.getElementById('new-custom-symbol').addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    addCustomSymbol();
                    e.preventDefault();
                }
            });
            </script>

